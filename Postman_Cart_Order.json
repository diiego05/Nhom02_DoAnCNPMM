              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_name\": \"Nguyễn Trí Lâm\",\n  \"phone_number\": \"0123456789\",\n  \"shipping_address\": \"1 Võ Văn Ngân, Thủ Đức\",\n  \"payment_method\": \"COD\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"product_variant_id\": 1,\n      \"quantity\": 2,\n      \"unit_price\": 150000\n    }\n  ]\n}"
