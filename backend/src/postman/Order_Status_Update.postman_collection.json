{
  "info": {
    "name": "Order Status Update API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Update Order Status to CONFIRMED",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{admin_token}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CONFIRMED\",\n  \"note\": \"Đã xác nhận đơn hàng\"\n}"
        },
        "url": {
          "raw": "http://localhost:8088/orders/{{order_id}}/status",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8088",
          "path": [
            "orders",
            "{{order_id}}",
            "status"
          ]
        }
      }
    },
